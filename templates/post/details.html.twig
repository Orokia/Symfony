{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}

<div class="container py-5">

    {% if post %}

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow-lg border-0">

                    {# IMAGE #}
                    {% if post.picture %}
                        <img src="{{ asset('uploads/images/' ~ post.picture) }}"
                             class="card-img-top"
                             style="max-height:400px; object-fit:cover;">
                    {% endif %}

                    <div class="card-body p-4">

                        
                        <h2 class="fw-bold mb-3">
                            {{ post.title }}
                        </h2>

                       
                        <p class="text-muted mb-4">
                            <i class="bi bi-calendar"></i>
                            {{ post.publishedAt|date('d M Y à H:i') }}
                        </p>

                        {# CONTENU #}
                        <div class="mb-4" style="line-height:1.7;">
                            {{ post.content|nl2br }}
                        </div>

                        <hr>

                      
                          <h4 class="mb-4">
                            💬 Commentaires ({{ post.comment|length }})
                        </h4>

                        {% set hasComment = false %}

                        {% for comment in post.comment %}

                            {# 🔥 FILTRE : uniquement approuvés #}
                            {% if comment.status == 'approved' %}

                                {% set hasComment = true %}

                                <div class="border rounded p-3 mb-3 shadow-sm">

                                    <div class="d-flex justify-content-between">

                                        <strong>
                                            {% if comment.user %}
                                                {{ comment.user.firstName }}
                                            {% else %}
                                                Anonyme
                                            {% endif %}
                                        </strong>

                                        <small class="text-muted">
                                            {{ comment.createdAt|date('d/m/Y H:i') }}
                                        </small>

                                    </div>

                                    <p class="mt-2 mb-0">
                                        {{ comment.content }}
                                    </p>

                                </div>

                            {% endif %}

                        {% endfor %}

                        {% if not hasComment %}
                            <p class="text-muted">Aucun commentaire validé pour le moment.</p>
                        {% endif %}
                        <hr>

                        
                       <div class="mt-5">

    <h5 class="mb-4 fw-bold">💬 Ajouter un commentaire</h5>

    {% if app.user %}

        <div class="card border-0 shadow-sm p-3">

            {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.content) }}
                    {{ form_widget(form.content, {
                        attr: {
                            class: 'form-control',
                            placeholder: 'Écris ton commentaire...',
                            rows: 4
                        }
                    }) }}
                    {{ form_errors(form.content) }}
                </div>

                <div class="text-end">
                    <button class="btn btn-primary px-4">
                        <i class="bi bi-send"></i> Envoyer
                    </button>
                </div>

            {{ form_end(form) }}

        </div>

    {% else %}

        <div class="alert alert-info text-center mt-3">
            <i class="bi bi-info-circle"></i>
            Connecte-toi pour laisser un commentaire
            <br>
            <a href="{{ path('app_login') }}" class="btn btn-sm btn-outline-primary mt-2">
                Se connecter
            </a>
        </div>

    {% endif %}

</div>
            </div>
        </div>

    {% else %}
        <p class="text-center">Article introuvable</p>
    {% endif %}

</div>

{% endblock %}