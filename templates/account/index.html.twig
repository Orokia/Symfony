{% extends 'base.html.twig' %}

{% block title %}Hello AccountController!{% endblock %}

{% block body %}

<section class="section">

    <div class="container" data-aos="fade-up">

        <!-- Titre -->
        <div class="section-title text-center">
            <h2>Mon Compte</h2>
            <p>Bienvenue dans votre espace personnel</p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success text-center">
                {{ message }}
            </div>
        {% endfor %}

        <div class="row justify-content-center">

            <div class="col-lg-6">

                <div class="p-4" style="background: #fff; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">

                    <!-- Avatar -->
                    <div class="mb-4 text-center">
                        <i class="bi bi-person-circle" style="font-size: 90px; color: #34b7a7;"></i>
                    </div>

                    <!-- User -->
                    <h3 class="mb-2 text-center">
                        {{ app.user.firstName }} {{ app.user.lastName }}
                    </h3>

                    <p class="text-muted text-center">
                        {{ app.user.email }}
                    </p>

                    <hr class="my-4">

                    <!-- FORMULAIRE -->
                    {{ form_start(form) }}

                        <div class="mb-3">
                            {{ form_label(form.firstName) }}
                            {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.lastName) }}
                            {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.plainPassword) }}
                            {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <button class="btn btn-primary w-100 mt-3">
                             Mettre à jour
                        </button>

                    {{ form_end(form) }}

                    <hr class="my-4">

                    <!-- Actions -->
                    <div class="d-grid gap-3">

                        <a href="{{ path('app_logout') }}" class="account-btn account-btn-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>
                            Se déconnecter
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

{% endblock %}